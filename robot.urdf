<?xml version="1.0"?>
<robot name="gearx_robot">

  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="1.0 0.6 0.3"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry><box size="1.0 0.6 0.3"/></geometry>
    </collision>
  </link>

  <link name="front_left_wheel">
    <visual>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.3 0.35 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.3 -0.35 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.3 0.35 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.3 -0.35 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <ros2_control name="RealRobot" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <joint name="virtual_planar_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

</robot>
